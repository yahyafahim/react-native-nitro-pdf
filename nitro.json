{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitropdf"
  ],
  "ios": {
    "iosModuleName": "NitroPdf"
  },
  "android": {
    "androidNamespace": [
      "nitropdf"
    ],
    "androidCxxLibName": "NitroPdf"
  },
  "autolinking": {
    "NitroPdf": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridNitroPdf"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridNitroPdf"
      }
    },
    "PdfDocument": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridPdfDocument"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridPdfDocument"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}